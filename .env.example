# =============================================================================
# Get Healthcare Frontend — environment template
# Copy to `.env` or `.env.local` and adjust values for your environment.
# =============================================================================

# NODE_ENV — set automatically by `npm run dev` / `npm run build` / `npm start`
# Options: development | production | test
# NODE_ENV=development

# -----------------------------------------------------------------------------
# NEXT_PUBLIC_API_URL — Laravel/backend API origin
# -----------------------------------------------------------------------------
# Production:  https://api.gethealthcare.ie
# Staging:     https://getsickcert-api.makeitlive.info
# Local:       http://localhost:8000
NEXT_PUBLIC_API_URL=https://api.gethealthcare.ie

# -----------------------------------------------------------------------------
# NEXT_PUBLIC_SITE_URL — public marketing site (canonical / Open Graph / sitemap)
# -----------------------------------------------------------------------------
# Production:  https://gethealthcare.ie
# Staging:     https://getsickcert.makeitlive.info
NEXT_PUBLIC_SITE_URL=https://gethealthcare.ie

# -----------------------------------------------------------------------------
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY — Stripe Checkout (client-side only)
# -----------------------------------------------------------------------------
# Test:  pk_test_...
# Live:  pk_live_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_key_here
